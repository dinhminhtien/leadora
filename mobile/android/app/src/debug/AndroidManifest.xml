<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Debug builds: allow plain-HTTP to ANY host (see the debug network
         security config) so hot reload / a LAN dev backend works regardless of
         the machine's IP. Overrides the release config below for debug only.
         Release/profile builds use @xml/network_security_config (HTTPS-only
         except the whitelisted dev hosts), so production stays HTTPS-only. -->
    <application
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:networkSecurityConfig" />
</manifest>

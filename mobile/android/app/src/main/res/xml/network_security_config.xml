<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security policy for release/profile builds.

  Production stays HTTPS-only (base-config cleartext = false). We only whitelist
  plain-HTTP for the known development backends so a *release* APK can be
  sideloaded onto a real device and still reach a LAN dev server for demos:
    * 10.0.2.2      — Android emulator alias for the host machine
    * 192.168.1.11  — this dev machine's Wi-Fi LAN IP (see config/device.json)
    * localhost     — on-device / adb-reverse setups
  Add your machine's LAN IP here if it changes (ipconfig → IPv4 Address).
  Debug builds use res/xml/network_security_config_debug.xml (all cleartext).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.1.11</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
